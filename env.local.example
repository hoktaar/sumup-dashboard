# SumUp API Keys - copy this file to .env.local and fill in your real API keys
# You can find your API keys in the SumUp Developer Portal: https://developer.sumup.com/

SUMUP_API_KEY_1=sup_sk_
SUMUP_API_KEY_2=sup_sk_
SUMUP_API_KEY_3=sup_sk_

# Optional: Custom display names for each account (defaults to "Konto 1/2/3" if not set)
SUMUP_ACCOUNT_NAME_1=Hauptfiliale
SUMUP_ACCOUNT_NAME_2=Zweigstelle Nord
SUMUP_ACCOUNT_NAME_3=Online Shop

# Standort-Namen für Mitarbeiter-Accounts (Format: email:Anzeigename)
# Bis zu 20 Einträge möglich (SUMUP_LOCATION_1 bis SUMUP_LOCATION_20)
SUMUP_LOCATION_1=ostend@beispiel.de:Filiale Ostend
SUMUP_LOCATION_2=mitte@beispiel.de:Filiale Mitte

# PIN-Schutz für das Dashboard (4-8 Stellen)
DASHBOARD_PIN=1234
